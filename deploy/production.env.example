# Use this value when building the frontend behind the provided Nginx config.
NEXT_PUBLIC_API_URL=/api

# Optional Keycloak settings. Leave empty to use the local login fallback.
# NEXT_PUBLIC_KEYCLOAK_URL=https://keycloak.example.com
# NEXT_PUBLIC_KEYCLOAK_REALM=ipam
# NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=ipam-web
# NEXT_PUBLIC_KEYCLOAK_REDIRECT_URI=http://YOUR_VM_HOSTNAME_OR_IP/
