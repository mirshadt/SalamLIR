[Unit]
Description=NetAtlas IPAM FastAPI backend
After=network.target

[Service]
Type=simple
User=ipam
Group=ipam
WorkingDirectory=/opt/netatlas-ipam
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/netatlas-ipam/backend/.venv/bin/python -m uvicorn backend.main:app --host 127.0.0.1 --port 3001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
